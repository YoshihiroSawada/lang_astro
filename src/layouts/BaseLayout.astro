---
/**
 * src/layouts/BaseLayout.astro
 * 全ページ共通レイアウト。ナビゲーションとフッターを含む。
 */
import { useTranslations, getLocaleFromUrl, translatePath, SUPPORTED_LOCALES, LOCALE_LABELS } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  title?: string;
}

const { locale, title } = Astro.props;
const t = useTranslations(locale);

const navLinks = [
  { key: 'nav.home',     href: translatePath('/', locale) },
  { key: 'nav.about',    href: translatePath('/about', locale) },
  { key: 'nav.services', href: translatePath('/services', locale) },
  { key: 'nav.contact',  href: translatePath('/contact', locale) },
];
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={t('meta.description')} />
  <title>{title ?? t('hero.title')} | i18n Demo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;700&family=DM+Serif+Display&family=Space+Mono&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ナビゲーション -->
  <header class="site-header">
    <nav class="nav-container">
      <a href={translatePath('/', locale)} class="site-logo">
        <span class="logo-mark">◆</span>
        i18n<span class="logo-accent">Demo</span>
      </a>

      <ul class="nav-links">
        {navLinks.map(link => (
          <li>
            <a href={link.href}>{t(link.key)}</a>
          </li>
        ))}
      </ul>

      <!-- 言語切替 -->
      <div class="lang-switcher">
        {SUPPORTED_LOCALES.map(loc => (
          <a
            href={translatePath(Astro.url.pathname, loc)}
            class:list={['lang-btn', { active: loc === locale }]}
            hreflang={loc}
          >
            {LOCALE_LABELS[loc]}
          </a>
        ))}
      </div>
    </nav>
  </header>

  <!-- メインコンテンツ -->
  <main>
    <slot />
  </main>

  <!-- フッター -->
  <footer class="site-footer">
    <div class="footer-inner">
      <p>{t('footer.rights')}</p>
      <div class="footer-lang">
        <span>{t('footer.lang')}:</span>
        {SUPPORTED_LOCALES.map(loc => (
          <a href={translatePath(Astro.url.pathname, loc)} hreflang={loc}
             class:list={[{ 'footer-lang-active': loc === locale }]}>
            {LOCALE_LABELS[loc]}
          </a>
        ))}
      </div>
    </div>
  </footer>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink:    #0d0d0d;
    --paper:  #f8f5ef;
    --accent: #c8433b;
    --mid:    #888;
    --border: #d8d3ca;
    --mono: 'Space Mono', monospace;
    --serif: 'DM Serif Display', serif;
    --sans: 'Noto Sans JP', sans-serif;
  }

  html { font-family: var(--sans); background: var(--paper); color: var(--ink); }
  body { min-height: 100vh; display: flex; flex-direction: column; }

  /* ── Header ── */
  .site-header {
    position: sticky; top: 0; z-index: 100;
    background: var(--paper);
    border-bottom: 2px solid var(--ink);
  }
  .nav-container {
    max-width: 1200px; margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex; align-items: center; gap: 2rem;
  }
  .site-logo {
    font-family: var(--mono); font-size: 1.1rem;
    text-decoration: none; color: var(--ink);
    display: flex; align-items: center; gap: .4rem;
    white-space: nowrap;
  }
  .logo-mark { color: var(--accent); }
  .logo-accent { color: var(--accent); }

  .nav-links {
    display: flex; gap: 0; list-style: none;
    margin-left: 2rem;
  }
  .nav-links a {
    display: block; padding: .5rem 1rem;
    text-decoration: none; font-size: .9rem; color: var(--ink);
    border-bottom: 2px solid transparent;
    transition: border-color .15s, color .15s;
  }
  .nav-links a:hover { border-bottom-color: var(--accent); color: var(--accent); }

  .lang-switcher {
    margin-left: auto;
    display: flex; gap: .25rem;
  }
  .lang-btn {
    font-family: var(--mono); font-size: .75rem;
    padding: .25rem .6rem;
    border: 1.5px solid var(--border);
    border-radius: 2px;
    text-decoration: none; color: var(--mid);
    transition: all .15s;
  }
  .lang-btn:hover { border-color: var(--ink); color: var(--ink); }
  .lang-btn.active { background: var(--ink); color: var(--paper); border-color: var(--ink); }

  /* ── Main ── */
  main { flex: 1; }

  /* ── Footer ── */
  .site-footer {
    border-top: 2px solid var(--ink);
    background: var(--ink); color: var(--paper);
    padding: 1.5rem 0;
  }
  .footer-inner {
    max-width: 1200px; margin: 0 auto;
    padding: 0 2rem;
    display: flex; justify-content: space-between; align-items: center;
    font-size: .8rem; font-family: var(--mono);
  }
  .footer-lang { display: flex; gap: .5rem; align-items: center; }
  .footer-lang a { color: var(--mid); text-decoration: none; }
  .footer-lang a:hover { color: var(--paper); }
  .footer-lang-active { color: var(--paper) !important; text-decoration: underline !important; }
</style>
