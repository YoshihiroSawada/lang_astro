# .env.example
# このファイルをコピーして .env を作成し、実際の値を設定してください
# cp .env.example .env

# ──────────────────────────────────────────────
# Google Apps Script Web App の公開URL
# GASエディタで「デプロイ」→「新しいデプロイ」→「ウェブアプリ」で取得
# ──────────────────────────────────────────────
GAS_ENDPOINT=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# ──────────────────────────────────────────────
# 未設定の場合 → モックデータを使用 (開発用)
# ──────────────────────────────────────────────
